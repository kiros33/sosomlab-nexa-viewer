{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexaMarkdownViewer",
  "mainBinaryName": "NexaMarkdownViewer",
  "version": "0.2.1",
  "identifier": "com.sosomlab.nexa-markdown-viewer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexa Markdown Viewer",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "rpm", "appimage"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown Document",
        "description": "Markdown 문서",
        "role": "Viewer",
        "mimeType": "text/markdown"
      }
    ],
    "publisher": "SosomLab",
    "copyright": "© 2026 SosomLab",
    "category": "Productivity",
    "shortDescription": "GitHub 스타일 Markdown 뷰어",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
